# Copy to ".env" (gitignored) for local `npm run upload` / `npm run deploy`.
# Never commit real values.
#
# run-upload.js merges this file over your shell: values here win (so you can
# switch targets in one terminal). List every SCREEPS_* you rely on per profile;
# variables not in the file still come from the shell. Use:
#   npm run upload -- .env.myserver
# to pick another file (see README).

# Official or any server that supports auth tokens:
# SCREEPS_HOST=screeps.com
# SCREEPS_BRANCH=main
# SCREEPS_TOKEN=

# Community server with username + password (no API token):
# SCREEPS_HOST=screeps.newbieland.com
# SCREEPS_BRANCH=test
# SCREEPS_USERNAME=
# SCREEPS_PASSWORD=
# Typical community: HTTP on port 80 (omit SCREEPS_PORT) or HTTP on 21025:
# SCREEPS_PROTOCOL=http
# SCREEPS_PORT=21025

# PTR (Public Test Realm) — copy relevant lines to ".env.ptr" (gitignored).
# The realm is selected by the URL path /ptr (same as grunt-screeps ptr: true), not
# by naming an editor branch "ptr" on the live server. Put the path on SCREEPS_HOST:
# SCREEPS_HOST=screeps.com/ptr
# SCREEPS_BRANCH=default
# SCREEPS_TOKEN=
