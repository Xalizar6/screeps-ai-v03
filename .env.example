# Copy to ".env" (gitignored) for local `npm run upload` / `npm run deploy`.
# Never commit real values.

# Official or any server that supports auth tokens:
# SCREEPS_HOST=screeps.com
# SCREEPS_BRANCH=main
# SCREEPS_TOKEN=

# Community server with username + password (no API token):
# SCREEPS_HOST=screeps.newbieland.com
# SCREEPS_BRANCH=test
# SCREEPS_USERNAME=
# SCREEPS_PASSWORD=
